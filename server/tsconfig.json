{
  "compilerOptions": {
    "target": "es2022",                          /* Define a versão do JavaScript de saída */
    "module": "commonjs",                        /* Define o sistema de módulos para o Node.js */
    "rootDir": "./src",                          /* Onde estão os nossos arquivos TypeScript */
    "outDir": "./dist",                          /* Onde o código JavaScript compilado será salvo */
    "esModuleInterop": true,                     /* Permite importar módulos CommonJS como Express sem problemas */
    "forceConsistentCasingInFileNames": true,   /* Garante que maiúsculas/minúsculas nos nomes de arquivos sejam respeitadas */
    "strict": true,                              /* Ativa todas as verificações estritas de tipo do TypeScript */
    "skipLibCheck": true                         /* Pula a verificação de tipos dos arquivos de declaração (.d.ts) das bibliotecas */
  },
  "include": ["src/**/*"]                        /* Diz ao TypeScript para compilar apenas o que está na pasta src */
}